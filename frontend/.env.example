# General
VITE_APP_NAME=Aiterra CRM
# Dev: use /api + Vite proxy (recommended). Or direct: http://127.0.0.1:8000/api
VITE_API_BASE_URL=/api
# Where Vite forwards /api (npm run dev / preview)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Direct backend URLs (if services are split)
VITE_META_ADS_API_URL=
VITE_META_APP_ID=
VITE_GOOGLE_ADS_API_URL=
VITE_BILLING_API_URL=

# Session storage key
VITE_AUTH_TOKEN_KEY=crm_auth_token

# Dev server port (optional)
VITE_DEV_PORT=5173
